rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Project Validation Helper
    function isValidProject(data) {
      return data.keys().hasAll(['name', 'code', 'userId', 'createdAt', 'updatedAt'])
        && data.keys().size() == 5
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.code is string && data.code.size() <= 1048576 // 1MB limit for code
        && data.userId == request.auth.uid
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    match /projects/{projectId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(projectId)
        && isValidProject(incoming());

      allow update: if isSignedIn()
        && isOwner(existing().userId)
        && isValidProject(incoming())
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'code', 'updatedAt']);

      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
